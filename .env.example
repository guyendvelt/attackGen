# AttackGen PostgreSQL connection (PLACEHOLDERS ONLY — never commit real secrets).
#
# Provide EITHER a single DATABASE_URL, or the individual POSTGRES_* values.
# DATABASE_URL takes precedence when both are set.

# Option A: one connection URL
DATABASE_URL=postgresql://attackgen:changeme@localhost:5432/attackgen

# Option B: individual settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=attackgen
POSTGRES_USER=attackgen
POSTGRES_PASSWORD=changeme
